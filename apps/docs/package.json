{
  "private": true,
  "name": "@isyuricunha/docs",
  "version": "0.0.0",
  "description": "The documentation for isyuricunha's projects",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build",
    "build:mdx": "content-collections build",
    "bundle-analyzer": "cross-env ANALYZE=true pnpm run build",
    "clean": "rm -rf .next .turbo .content-collections",
    "dev": "next dev --turbo -p 3002",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint --fix .",
    "start": "next start -p 3002",
    "type-check": "pnpm build:mdx && tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@isyuricunha/ui": "workspace:*",
    "@isyuricunha/utils": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "geist": "^1.7.1",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "shiki": "^4.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@content-collections/cli": "^0.1.9",
    "@content-collections/core": "^0.15.0",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/next": "^0.2.11",
    "@isyuricunha/eslint-config": "workspace:*",
    "@isyuricunha/mdx-plugins": "workspace:*",
    "@isyuricunha/shared": "workspace:*",
    "@isyuricunha/tsconfig": "workspace:*",
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "postcss": "^8.5.15",
    "postcss-load-config": "^6.0.1",
    "tailwindcss": "^4.3.0"
  },
  "lint-staged": {
    "*.{cjs,mjs,js,jsx,cts,mts,ts,tsx}": "pnpm -w exec eslint --fix --max-warnings 999"
  },
  "packageManager": "pnpm@10.28.0"
}

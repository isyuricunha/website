{
  "private": true,
  "name": "@isyuricunha/web",
  "version": "0.0.0",
  "description": "The personal portfolio of isyuricunha",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "build:mdx": "content-collections build",
    "bundle-analyzer": "cross-env ANALYZE=true pnpm run build",
    "clean": "rm -rf .next .turbo .content-collections test-results playwright-report",
    "dev": "pnpm with-env next dev -p 3000",
    "lint": "pnpm -w exec eslint . --max-warnings 0",
    "lint:fix": "pnpm -w exec eslint --fix .",
    "start": "pnpm with-env next start -p 3000",
    "test:e2e": "cross-env NODE_ENV=test pnpm with-env playwright test",
    "test:e2e:inspector": "cross-env NODE_ENV=test pnpm with-env playwright test $1 --debug",
    "test:e2e:ui": "cross-env NODE_ENV=test pnpm with-env playwright test --ui",
    "type-check": "pnpm build:mdx && tsc --noEmit --project tsconfig.json",
    "with-env": "dotenv -e ../../.env.local --"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@hookform/resolvers": "5.4.0",
    "@icons-pack/react-simple-icons": "13.13.0",
    "@isyuricunha/db": "workspace:*",
    "@isyuricunha/emails": "workspace:*",
    "@isyuricunha/env": "workspace:*",
    "@isyuricunha/i18n": "workspace:*",
    "@isyuricunha/ui": "workspace:*",
    "@isyuricunha/utils": "workspace:*",
    "@marsidev/react-turnstile": "^1.5.2",
    "@mistralai/mistralai": "^2.2.5",
    "@number-flow/react": "^0.6.0",
    "@octokit/rest": "^22.0.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "@react-email/render": "^2.0.8",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "11.17.0",
    "@trpc/react-query": "11.17.0",
    "@trpc/server": "11.17.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "better-auth": "1.6.12",
    "class-variance-authority": "^0.7.1",
    "cobe": "^2.0.1",

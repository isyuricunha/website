    "@content-collections/mdx": "^0.2.2",
    "@content-collections/next": "^0.2.11",
    "@isyuricunha/eslint-config": "workspace:*",
    "@isyuricunha/kv": "workspace:*",
    "@isyuricunha/mdx-plugins": "workspace:*",
    "@isyuricunha/shared": "workspace:*",
    "@isyuricunha/tsconfig": "workspace:*",
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/rss": "^0.0.32",
    "@vitejs/plugin-react": "^6.0.2",
    "better-call": "1.3.5",
    "esbuild": "0.28.0",
    "fast-xml-parser": "^5.8.0",
    "jiti": "^2.7.0",
    "postcss": "^8.5.15",
    "postcss-load-config": "^6.0.1",
